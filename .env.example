# Database (Neon.tech থেকে free PostgreSQL নাও)
DATABASE_URL="postgresql://username:password@host/dbname?sslmode=require"

# NextAuth (যেকোনো random 32+ character string)
NEXTAUTH_SECRET="rocky-chowdhury-super-secret-key-change-this-2024"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (console.cloud.google.com থেকে নাও)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Anthropic AI API (console.anthropic.com থেকে নাও)
ANTHROPIC_API_KEY="sk-ant-your-api-key-here"
